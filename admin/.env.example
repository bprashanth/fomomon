# Required. AWS region for Cognito, S3, and IAM (for example: ap-south-1).
AWS_REGION=

# Required. S3 bucket holding org data, sites.json, users.json, and auth_config.json.
FOMOMON_BUCKET=

# Optional. Defaults to "auth_config.json". Key path inside the bucket for the auth config.
AUTH_CONFIG_KEY=
